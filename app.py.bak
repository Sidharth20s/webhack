@app.route('/files', methods=['GET'])
def access_files():
    """VULNERABLE: Path traversal to read arbitrary files"""
    file_path = request.args.get('path', '')
    
    # LOG POISONING: Log file path requests without sanitization
    user_agent = request.headers.get('User-Agent', 'Unknown')
    main_logger.info(f"File access request: {file_path} | User-Agent: {user_agent}")
    
    if not file_path:
        return "No file specified"
    
    # VULNERABLE: Weak path traversal protection
    safe_path = file_path.replace('../', '')  # Only removes once!
    
    # Bypass examples:
    # /files?path=....//../etc/passwd -> becomes ../../etc/passwd
    # /files?path=..%2f..%2fetc%2fpasswd -> URL decoded to path traversal
    # /files?path=....//....//etc/passwd -> becomes ..//..//etc/passwd after one removal
    
    full_path = os.path.join('uploads', safe_path)
    
    try:
        if os.path.exists(full_path) and os.path.isfile(full_path):
            with open(full_path, 'r', errors='ignore') as f:
                content = f.read()
                log_success("File accessed", {"path": safe_path})
                
                # Return file content (could be sensitive)
                return f'''
                <html>
                <body>
                <h2>File Contents: {safe_path}</h2>
                <pre>{content}</pre>
                </body>
                </html>
                '''
        else:
            log_failure("File not found", {"path": safe_path})
            return "File not found", 404
    except Exception as e:
        log_failure("File access error", {"path": safe_path, "error": str(e)})
        return f"Error reading file: {str(e)}", 500

