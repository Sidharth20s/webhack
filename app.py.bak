# ============================================
# VULNERABILITY 4: RACE CONDITION - Session Handling
# ============================================
def create_session_with_race_condition(username, user_id):
    """VULNERABLE: Session creation susceptible to race conditions"""
    session_dir = 'sessions'
    os.makedirs(session_dir, exist_ok=True)
    
    # RACE CONDITION: Multiple threads could create same session
    # Window between check and write
    session_file = os.path.join(session_dir, f'{user_id}_{datetime.now().timestamp()}.sess')
    
    # No lock - multiple processes can write simultaneously
    time.sleep(0.01)  # Simulate processing
    
    with open(session_file, 'w') as f:
        json.dump({'user_id': user_id, 'username': username}, f)
    
    return session_file

@app.route('/api/rapid-login', methods=['POST'])
def rapid_login():
    """VULNERABLE: Race condition with rapid concurrent logins"""
    username = request.form.get('username')
    password = request.form.get('password')
    
    # Simulate rapid login attempts (race condition window)
    for i in range(3):
        session_file = create_session_with_race_condition(username, i)
        time.sleep(0.001)  # Minimal delay between session creates
    
    session['user_id'] = i
    session['username'] = username
    log_success("Rapid login processed", {"username": username})
    
    return jsonify({'status': 'logged_in'})

