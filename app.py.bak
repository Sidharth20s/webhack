@app.route('/search')
def search():
    query = request.args.get('q', '')
    user_id = session.get('user_id', 'Unknown')
    username = session.get('username', 'Unknown')
    client_ip = request.remote_addr
    
    conn = sqlite3.connect('vulnerable.db')
    c = conn.cursor()
    c.execute("SELECT * FROM posts WHERE title LIKE ?", (f'%{query}%',))
    results = c.fetchall()
    conn.close()
    
    # VULNERABLE: XSS - user input reflected without escaping
    html = f"<h2>Search results for: {query}</h2>"
    for post in results:
        html += f"<div><h3>{post[2]}</h3><p>{post[3]}</p></div>"
    
    log_success("Search performed", {"query": query, "username": username, "user_id": user_id, "results_count": len(results), "ip": client_ip})
    return html

# ============================================
# VULNERABILITY 1: MULTI-LAYER VALIDATION BYPASS
# ============================================
# These functions create a false sense of security

def check_extension_whitelist(filename):
    """VULNERABLE: Only checks extension, easily bypassed"""
    allowed_extensions = ['.jpg', '.jpeg', '.png']
    file_ext = os.path.splitext(filename)[1].lower()
    
    # Bypass: null byte injection (.php%00.jpg), double extension (.jpg.php)
    return file_ext in allowed_extensions

def check_content_type(file):
    """VULNERABLE: Content-Type header is client-controlled"""
    content_type = file.content_type
    allowed_types = ['image/jpeg', 'image/png']
    return content_type in allowed_types

def check_magic_bytes(file_data):
    """VULNERABLE: Only checks first 4 bytes, image comments can hide PHP"""
    magic_bytes = {
        b'\xFF\xD8\xFF': 'jpeg',
        b'\x89\x50\x4E\x47': 'png',
        b'\x47\x49\x46': 'gif'
    }
    
    for magic, fmt in magic_bytes.items():
        if file_data.startswith(magic):
            return True
    return False

def unsafe_resize_image_preserving_metadata(file_data, filename):
    """VULNERABLE: Preserves EXIF/metadata including embedded PHP code in comments"""
    try:
        img = Image.open(BytesIO(file_data))
        
        # VULNERABLE: Attempts to preserve all metadata including PHP in comments
        # The resized image can still contain PHP code in EXIF tags
        img.thumbnail((800, 600))
        
        output = BytesIO()
        img.save(output, format=img.format, quality=85)
        return output.getvalue()
    except:
        # If image processing fails, return original (which might contain PHP)
        return file_data

# ============================================
# VULNERABILITY 2: PATH TRAVERSAL
# ============================================
def unsafe_sanitize_filename(filename):
    """VULNERABLE: Only removes '../' once - easily bypassed"""
    # Weak sanitization - only removes ../ once
    sanitized = filename.replace('../', '')
    
    # BYPASS: '....//' becomes '../' after one removal
    # BYPASS: URL encoding '..%2f' can be decoded by server
    # BYPASS: Unicode normalization '..\u2215'
    return sanitized

# ============================================
# VULNERABILITY 3: LOG POISONING
# ============================================
def log_user_agent_unsafe(logger, client_ip):
    """VULNERABLE: User-Agent header logged without sanitization"""
    user_agent = request.headers.get('User-Agent', 'Unknown')
    # User-Agent can contain PHP code, HTML, shell commands that get logged
    # If logs are then parsed by a web server, can achieve RCE
    logger.info(f"Request from {client_ip} with User-Agent: {user_agent}")

# ============================================
# VULNERABILITY 4: RACE CONDITION
# ============================================
upload_lock = threading.Lock()
concurrent_uploads = {}

def concurrent_file_write_race(filepath, file_data):
    """VULNERABLE: Race condition in file writing"""
    global concurrent_uploads
    
    # Simulate multiple writes without proper locking
    time.sleep(0.01)  # Simulate I/O delay
    with open(filepath, 'wb') as f:
        # First concurrent upload could be overwritten
        f.write(file_data)
    
    # VULNERABLE: Session file can be manipulated during write
    session_file = f"sessions/{request.cookies.get('session_id', 'unknown')}.sess"
    # Window for attacker to modify session before write completes
    time.sleep(0.01)

