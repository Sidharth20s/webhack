@app.route('/api/system-command', methods=['POST'])
def system_command():
    """VULNERABLE: Direct command execution for privilege escalation"""
    if 'user_id' not in session:
        return jsonify({'error': 'Not authenticated'}), 401
    
    username = session.get('username', 'Unknown')
    user_role = session.get('role', 'user')
    
    # VULNERABLE: Command injection - subprocess with user input
    command = request.form.get('cmd', '')
    
    if user_role == 'admin':  # Weak privilege check
        try:
            # DANGEROUS: shell=True with user input allows command injection
            result = subprocess.run(command, shell=True, capture_output=True, text=True, timeout=5)
            
            log_change("System command executed", {
                "command": command[:100],
                "user": username,
                "success": result.returncode == 0
            })
            
            return jsonify({
                'output': result.stdout,
                'error': result.stderr,
                'returncode': result.returncode
            })
        except Exception as e:
            log_failure("Command execution failed", {"error": str(e)})
            return jsonify({'error': str(e)}), 500
    else:
