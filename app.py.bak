# ============================================
def check_system_access():
    """VULNERABLE: Attempts to access sensitive system files"""
    sensitive_files = [
        '/etc/passwd',
        '/etc/shadow', 
        '/Windows/System32/config/SAM',
        'C:\\Windows\\System32\\config\\SAM'
    ]
    
    for filepath in sensitive_files:
        try:
            with open(filepath, 'r') as f:
                return True
        except:
            pass
    return False

