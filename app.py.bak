# VULNERABILITY 5: PRIVILEGE ESCALATION
# ============================================
def execute_image_resize_as_subprocess(file_data, filename):
    """VULNERABLE: Using subprocess with user input - can lead to RCE"""
    try:
        # DANGEROUS: subprocess with user-controlled filename
        # Command injection possible if filename has special chars
        result = subprocess.run(
            f"python -c \"from PIL import Image; Image.open('{filename}').thumbnail((800,600))\"",
            shell=True,
            capture_output=True,
            timeout=5
        )
        return result.returncode == 0
    except:
        return False

# Existing function from app.py
@app.route('/upload', methods=['GET', 'POST'])
def upload():
    if 'user_id' not in session:
        log_failure("Upload access denied", {"reason": "User not authenticated"})
        return redirect('/login')
    
    username = session.get('username', 'Unknown')
    user_id = session.get('user_id')
    client_ip = request.remote_addr
    
    if request.method == 'POST':
        file = request.files.get('file')
        
        # LOG POISONING: Log User-Agent without sanitization
        log_user_agent_unsafe(main_logger, client_ip)
        
        if file and file.filename:
            filename = file.filename
            
            # MULTI-LAYER VALIDATION (all can be bypassed)
            ext_check = check_extension_whitelist(filename)
            content_type_check = check_content_type(file)
            file.seek(0)
            file_data = file.read()
            magic_check = check_magic_bytes(file_data)
            
            # All checks must pass (but easily bypassed)
            if ext_check and content_type_check and magic_check:
                # VULNERABLE: Resize while preserving metadata with PHP
                processed_data = unsafe_resize_image_preserving_metadata(file_data, filename)
                
                # PATH TRAVERSAL: Weak filename sanitization
                safe_filename = unsafe_sanitize_filename(filename)
                
                # RACE CONDITION: No proper locking on concurrent uploads
                upload_path = f'uploads/{safe_filename}'
                
                # Check for path traversal attempts to log them (good IDS evasion)
                if '../' in filename or '..\\' in filename:
                    log_failure("Path traversal attempt detected", 
                               {"filename": filename, "username": username, "ip": client_ip})
                
                try:
                    # RACE CONDITION: Write without proper synchronization
                    concurrent_file_write_race(upload_path, processed_data)
                    
                    log_change("File uploaded (with validation)", 
                              {"filename": filename, "safe_filename": safe_filename,
                               "username": username, "user_id": user_id, "ip": client_ip})
                    log_success("File upload completed", 
                               {"filename": safe_filename, "user": username})
                    
                    return f'''
                    <html>
                    <body>
                    <h2>Upload Successful!</h2>
                    <p>File '{safe_filename}' uploaded and validated successfully!</p>
                    <p>Multi-layer validation passed:</p>
                    <ul>
                    <li>Extension whitelist: ✓</li>
                    <li>Content-Type verification: ✓</li>
                    <li>Magic byte checking: ✓</li>
                    <li>Image resizing: ✓</li>
                    </ul>
                    <p>View uploaded file: <a href="/uploads/{safe_filename}">/uploads/{safe_filename}</a></p>
                    <a href="/upload">Upload another file</a>
                    </body>
                    </html>
                    '''
                except Exception as e:
                    log_failure("File upload error", 
                               {"filename": filename, "error": str(e), "username": username})
                    return f"Error uploading file: {str(e)}"
            else:
                # Log what failed
                failed_checks = []
                if not ext_check:
                    failed_checks.append("extension")
                if not content_type_check:
                    failed_checks.append("content-type")
                if not magic_check:
                    failed_checks.append("magic-bytes")
                
                log_failure("File upload validation failed", 
                           {"filename": filename, "failed_checks": failed_checks, 
                            "username": username, "ip": client_ip})
                
                return f'''
                <html>
                <body>
                <h2>Upload Failed - Validation Error</h2>
                <p>File validation failed on: {', '.join(failed_checks)}</p>
                <p>Only .jpg and .png files are allowed.</p>
                <a href="/upload">Try again</a>
                </body>
                </html>
                '''
        else:
            log_failure("File upload failed", 
                       {"reason": "No file provided", "username": username, "user_id": user_id})
            return "No file provided!"
    
    return render_template('upload.html')

